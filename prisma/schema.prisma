// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init


datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       Int       @id @default(autoincrement())
  name     String
  email    String    @unique
  projects Project[]
  skills   Skill[]
}

model Project {
  id          Int    @id @default(autoincrement())
  title       String
  description String?
  user        User   @relation(fields: [userId], references: [id])
  userId      Int
}

model Skill {
  id     Int    @id @default(autoincrement())
  name   String
  level  String? // Beginner, Intermediate, Expert
  user   User    @relation(fields: [userId], references: [id])
  userId Int
}
